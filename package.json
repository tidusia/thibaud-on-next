{
  "name": "thibaud-on-next",
  "description": "Personal website on Next.js",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "formatters": "npm run prettier:check && npm run lint && npm run typescript:check",
    "integrity": "npm run formatters && npm run build && npm run storybook:build && npm run jest:all && npm run storybook:test:integrity",
    "jest:all": "jest",
    "jest:watch": "jest --watch",
    "lint-TODO": "next lint -- --ignore-path .gitignore",
    "pre-commit-TODO": "lint-staged --verbose && npm run typescript:check && jest -o && npm run storybook:test:only-changed",
    "pre-commit": "npm run typescript:check && jest -o && npm run storybook:test:only-changed",
    "prepare": "husky install",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "start": "next start",
    "storybook:build": "storybook build",
    "storybook:dev": "storybook dev -p 6006",
    "storybook:test": "test-storybook --url http://localhost:6006 --browsers chromium",
    "storybook:test:integrity": "start-server-and-test storybook:dev 6006 storybook:test",
    "storybook:test:only-changed": "start-server-and-test storybook:dev 6006 'npm run storybook:test -- -- -o'",
    "typescript:check": "tsc --noEmit"
  },
  "author": "@tidusia",
  "license": "MIT",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mapbox/rehype-prism": "^0.9.0",
    "@vercel/analytics": "^1.5.0",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "next": "^16.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.1.0",
    "rehype-raw": "^7.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.0.8",
    "@storybook/addon-docs": "^10.0.8",
    "@storybook/addon-links": "^10.0.8",
    "@storybook/nextjs": "^10.0.8",
    "@storybook/test-runner": "^0.24.1",
    "@tailwindcss/forms": "^0.5.10",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.25",
    "@types/react": "^18.3.27",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.33",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-storybook": "^10.0.8",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "start-server-and-test": "^2.1.3",
    "storybook": "^10.0.8",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3"
  }
}
