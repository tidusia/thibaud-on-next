{
  "name": "thibaud-on-next",
  "description": "Personal website on Next.js",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "formatters": "npm run prettier:check && npm run eslint && npm run typescript:check",
    "integrity": "npm run formatters && npm run build && npm run storybook:build && npm run jest:all && npm run storybook:test:integrity",
    "jest:all": "jest",
    "jest:watch": "jest --watch",
    "eslint": "eslint .",
    "pre-commit": "lint-staged --verbose && npm run typescript:check && jest -o && npm run storybook:test:only-changed",
    "prepare": "husky",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "start": "next start",
    "storybook:build": "storybook build",
    "storybook:dev": "storybook dev -p 6006",
    "storybook:test": "test-storybook --url http://localhost:6006 --browsers chromium",
    "storybook:test:integrity": "start-server-and-test storybook:dev 6006 storybook:test",
    "storybook:test:only-changed": "start-server-and-test storybook:dev 6006 'npm run storybook:test -- -- -o'",
    "typescript:check": "tsc --noEmit"
  },
  "author": "@tidusia",
  "license": "MIT",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@vercel/analytics": "^1.6.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "next": "^16.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.2",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-links": "^10.2.10",
    "@storybook/nextjs-vite": "10.2.10",
    "@storybook/test-runner": "^0.24.2",
    "@tailwindcss/forms": "^0.5.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^24",
    "@types/react": "^19.2.7",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.9.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.2.10",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "start-server-and-test": "^2.1.3",
    "storybook": "^10.2.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
